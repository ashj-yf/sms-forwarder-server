DATABASE_URL=sqlite:///./smsf.db
PUBLIC_BASE_URL=http://localhost:8000
JWT_SECRET=change-me-jwt-secret
APP_SECRET=change-me-app-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
HTTP_TIMEOUT_SECONDS=10
WEBHOOK_RATE_LIMIT_PER_MINUTE=120
USER_QUERY_RATE_LIMIT_PER_MINUTE=30
FRPS_ENABLED=false
FRPS_INTERNAL_HOST=127.0.0.1
FRPS_PUBLIC_HOST=localhost
FRPS_BIND_PORT=7000
FRPS_AUTH_TOKEN=change-me-frps-token
FRPS_ALLOW_PORT_MIN=17000
FRPS_ALLOW_PORT_MAX=17999
FRPS_DASHBOARD_PORT=7500
FRPS_DASHBOARD_USER=admin
FRPS_DASHBOARD_PASSWORD=change-me
TUNNEL_PROXY_DEFAULT_USE_ENCRYPTION=true
TUNNEL_PROXY_DEFAULT_USE_COMPRESSION=true
